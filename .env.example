# =============================================================================
# AI Resume-Job Matching Application — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Supabase ---
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Anthropic (Claude) ---
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Firecrawl ---
# Get from: https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-xxxxx

# --- Discord ---
# Create webhook: Discord Server → Channel Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/xxxxx

# --- Application Settings ---
MATCH_THRESHOLD=80
SCRAPE_MAX_JOBS_PER_SOURCE=50
LOG_LEVEL=INFO

# --- API Settings ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Service API Key (for GitHub Actions / automated triggers) ---
# Generate a random string: python -c "import secrets; print(secrets.token_urlsafe(32))"
SERVICE_API_KEY=your-random-service-key

# --- Render Deployment ---
# These are set automatically by Render, but needed for GitHub Actions
API_BASE_URL=https://your-app.onrender.com
